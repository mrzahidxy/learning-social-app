# Supabase project settings
# Find these in Supabase Dashboard > Project Settings > API.
PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"

# Server-only key used to create signed Storage upload URLs.
# Never expose this value through a PUBLIC_ variable.
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# Supabase PostgreSQL connection strings
# Use the transaction pooler URL for normal application queries.
DATABASE_URL="postgresql://postgres.your-project-ref:your-password@aws-0-your-region.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Use the direct database URL for Prisma migrations and administrative operations.
DIRECT_URL="postgresql://postgres:your-password@db.your-project-ref.supabase.co:5432/postgres"

# Existing user ID from Supabase Dashboard > Authentication > Users.
# The seed creates or promotes this profile to ADMIN and adds one demo article.
# It is safe to run repeatedly.
SEED_ADMIN_USER_ID="00000000-0000-4000-8000-000000000000"
